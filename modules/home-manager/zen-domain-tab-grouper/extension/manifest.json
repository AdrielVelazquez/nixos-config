{
  "manifest_version": 2,
  "name": "Zen Domain Tab Grouper",
  "description": "Automatically groups Zen tabs by URL domain.",
  "version": "0.3.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-domain-tab-grouper@adriel.local",
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "contextMenus",
    "tabs",
    "tabGroups"
  ],
  "background": {
    "scripts": [
      "domain.js",
      "tabs.js",
      "background.js"
    ]
  }
}
